# ── DocFusion Copilot Backend 环境配置 ──
# 复制此文件为 .env 并填入真实值：cp .env.example .env

# ── 服务器 ──
DOCFUSION_HOST=127.0.0.1
DOCFUSION_PORT=8000
DOCFUSION_MAX_WORKERS=4

# ── 数据库 ──
DOCFUSION_DATABASE_URL=postgresql+psycopg://postgres:postgres@127.0.0.1:5432/docfusion_copilot
# DOCFUSION_DATABASE_ECHO=false

# ── OpenAI 兼容 LLM（可选，不配置则回退到本地规则） ──
DOCFUSION_OPENAI_API_KEY=
DOCFUSION_OPENAI_BASE_URL=
DOCFUSION_OPENAI_MODEL=
DOCFUSION_OPENAI_TIMEOUT_SECONDS=90

# ── CORS ──
DOCFUSION_CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
DOCFUSION_CORS_ALLOW_METHODS=*
DOCFUSION_CORS_ALLOW_HEADERS=*
DOCFUSION_CORS_ALLOW_CREDENTIALS=false
