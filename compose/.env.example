# ─────────────────────────────────────────────────────────────
# DocFusion Copilot — Docker Compose 环境变量模板
# 用法：cp .env.example .env  然后填写必填项
# ─────────────────────────────────────────────────────────────

# ── 端口映射（宿主机端口，改这里不需要改 Dockerfile）──────────
BACKEND_PORT=8000
FRONTEND_PORT=8080
POSTGRES_PORT=5432

# ── PostgreSQL ──────────────────────────────────────────────
POSTGRES_PASSWORD=postgres

# ── LLM（必填）──────────────────────────────────────────────
# DeepSeek 示例，也可换成其他 OpenAI-compatible 接口
DOCFUSION_OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
DOCFUSION_OPENAI_BASE_URL=https://api.deepseek.com
DOCFUSION_OPENAI_MODEL=deepseek-chat
DOCFUSION_OPENAI_TIMEOUT_SECONDS=45

# ── 向量检索 / Embedding（选填，不填则禁用语义搜索）─────────
# 注册 https://siliconflow.cn 即可获取免费 API Key
DOCFUSION_EMBEDDING_API_KEY=
DOCFUSION_EMBEDDING_BASE_URL=https://api.siliconflow.cn/v1
DOCFUSION_EMBEDDING_MODEL=BAAI/bge-m3
